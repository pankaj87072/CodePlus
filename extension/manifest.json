{
  "manifest_version": 3,
  "name": "CodePulse - LeetCode Timer & Solve Tracker",
  "version": "2.0.0",
  "description": "Floating solve-timer for LeetCode with Google sign-in and a personalized target time, backed by your own account history.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "alarms", "identity"],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:8000/*",
    "https://*.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["dist/inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["dist/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/inject.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
