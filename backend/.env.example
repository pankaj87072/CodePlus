# --- Database (Supabase Postgres connection string) -------------------------
# Found in Supabase dashboard -> Project Settings -> Database -> Connection string
# Use the "URI" format, e.g.:
# postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# --- Supabase Auth ------------------------------------------------------------
# Project Settings -> API -> Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings -> API -> JWT Secret (used to verify tokens the extension sends us)
SUPABASE_JWT_SECRET=replace-with-your-supabase-jwt-secret

# --- CORS ---------------------------------------------------------------------
# Comma-separated list. Must include your unpacked extension's origin
# (chrome-extension://<your-extension-id>) and the dashboard's dev origin.
CORS_ORIGINS=http://localhost:5173

# --- Misc -----------------------------------------------------------------
ENVIRONMENT=development
